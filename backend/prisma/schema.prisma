// This Prisma schema maps the Task Management Dashboard AppData model into Postgres.
// It is intended to back /api/app-data and /api/snapshot endpoints.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}








datasource db {
  provider = "postgresql"
}


// ===== Enums =====

enum TaskStatus {
  backlog
  in_testing
  evaluating
  reporting
  done
}

enum Role {
  ADMIN
  MANAGER
  TESTER
  VIEWER
}


enum Priority {
  P0
  P1
  P2
}

// ===== Core reference tables =====

model Project {
  id        String   @id
  name      String
  platform  String
  genre     String
  status    String   // 'active' | 'archived'
  color     String
  createdAt DateTime

  tasks     Task[]
  scorecards GameScorecard[]
}

model Member {
  id         String   @id
  name       String
  email      String   @unique
  role       String
  avatarColor String
  initials   String
  joinedAt   DateTime
  password   String   // hashed password

  tasks      Task[]
  scorecards GameScorecard[]
  insights   WeeklyInsight[]
}

// ===== Tasks =====

model Task {
  id          String     @id
  title       String
  description String

  projectId   String
  assigneeId  String

  status      TaskStatus
  priority    Priority
  weight      Int
  deadline    DateTime?

  createdAt   DateTime
  completedAt DateTime?

  // Eisenhower matrix
  eisenhowerUrgent      Boolean @default(false)
  eisenhowerImportant   Boolean @default(false)
  eisenhowerAutoClassified Boolean @default(false)

  tags        Json? // keep array as JSON

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    Member     @relation(fields: [assigneeId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
}

// ===== Status/priority configs =====
// These are static-ish, but stored so frontend can edit if needed.

model StatusConfig {
  id    TaskStatus @id
  label String
  color String
  order Int
}

model PriorityConfig {
  id           Priority @id
  label        String
  color        String
  defaultWeight Int
}

// ===== Scorecards & Insights =====

model GameScorecard {
  id        String   @id
  projectId String
  week      DateTime

  ratingsCoreLoop       Int
  ratingsMonetization   Int
  ratingsVisualUx       Int
  ratingsRetention      Int
  ratingsUsp            Int

  summary   String

  authorId  String
  createdAt DateTime

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    Member  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([week])
  @@index([authorId])
}

model WeeklyInsight {
  id            String   @id
  week          DateTime
  title         String
  overallStatus String

  highlights    Json?
  risks         Json?
  actionItems   Json?

  authorId      String
  createdAt     DateTime

  author        Member @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([week])
  @@index([authorId])
}

// ===== Snapshots =====
// Stores full AppData snapshot to preserve current feature parity.

model Snapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @db.Date

  payload      Json
  createdAt    DateTime @default(now())

  @@unique([snapshotDate])
}

